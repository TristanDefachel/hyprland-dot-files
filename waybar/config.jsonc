// ~/.config/waybar/config.jsonc
{
    "layer": "top",
    "margin-top": 5,
    "margin-left": 8,
    "margin-right": 8,
    "modules-left": [
        "hyprland/workspaces",
        "mpris"
    ],
    "modules-center": [
        "group/group-toolbox",
        "clock",
        "custom/notification"
    ],
    "modules-right": [
        "group/audio",
        "bluetooth",
        "network",
        "battery",
        "custom/power"
    ],
    "group/group-toolbox": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 650,
            "transition-left-to-right": true,
            "click-to-reveal": true
        },
        "modules": [
            "custom/toolbox",
            "power-profiles-daemon",
            "cpu",
            "load",
            "temperature"
        ]
    },
    "group/audio": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 650,
            "transition-left-to-right": false
        },
        "modules": [
            "pulseaudio",
            "pulseaudio/slider",
            "pulseaudio#microphone"
        ]
    },
    "include": [
        "~/.config/waybar/modules.jsonc"
    ]
}